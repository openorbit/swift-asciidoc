// Double-column layout with a header stack.
pages[
  page(master:"default")[
    stack[
      flow(slot("title")),
      flow(slot("abstract")),
      flow(slot("authors")),
      // Content assigns slot="left" and slot="right" for columns.
      grid[
        place(area:"left")[ flow(slot("left")) ],
        place(area:"right")[ flow(slot("right")) ]
      ]
    ]
  ]
]
